generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String   @map("password_hash")
  role             Role     @default(USER)
  firstName        String?  @map("first_name")
  lastName         String?  @map("last_name")
  telegramUsername String?  @map("telegram_username")
  balanceKopecks   Int      @default(0) @map("balance_kopecks")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  sessions              Session[]
  briefs                Brief[]
  subscription          Subscription?
  payments              Payment[]
  provisioningJob       ProvisioningJob?
  supportTickets        SupportTicket[]
  auditLogs             AuditLog[]
  vpnCerts              VpnCert[]
  balanceTransactions   BalanceTransaction[]
  assistantSubs         AssistantSubscription[]

  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @map("refresh_token_hash")
  userAgent        String?  @map("user_agent")
  ip               String?
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Brief {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  title     String      @default("Мой бриф")
  dataJson  Json        @map("data_json")
  status    BriefStatus @default(DRAFT)
  botName   String?     @map("bot_name")
  botStatus String      @default("pending") @map("bot_status")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assistantSubs AssistantSubscription[]

  @@map("briefs")
}

model Subscription {
  id               String             @id @default(uuid())
  userId           String             @unique @map("user_id")
  status           SubscriptionStatus @default(ACTIVE)
  provider         String?
  currentPeriodEnd DateTime?          @map("current_period_end")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("subscriptions")
}

model Payment {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  subscriptionId  String?       @map("subscription_id")
  provider        String
  providerPaymentId String      @unique @map("provider_payment_id")
  amount          Int
  currency        String        @default("RUB")
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  events       PaymentEvent[]

  @@map("payments")
}

model PaymentEvent {
  id             String   @id @default(uuid())
  provider       String
  providerEventId String  @unique @map("provider_event_id")
  paymentId      String?  @map("payment_id")
  payloadJson    Json     @map("payload_json")
  createdAt      DateTime @default(now()) @map("created_at")

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("payment_events")
}

model ProvisioningJob {
  id           String              @id @default(uuid())
  userId       String              @unique @map("user_id")
  status       ProvisioningStatus  @default(DRAFT)
  step         ProvisioningStep    @default(NONE)
  serverId     String?             @map("server_id")
  serverIp     String?             @map("server_ip")
  logsShort    String?             @map("logs_short")
  errorCode    String?             @map("error_code")
  errorMessage String?             @map("error_message")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("provisioning_jobs")
}

model SupportTicket {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  subject   String
  status    TicketStatus  @default(OPEN)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id         String     @id @default(uuid())
  ticketId   String     @map("ticket_id")
  authorType AuthorType @map("author_type")
  message    String
  createdAt  DateTime   @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  action      String
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  metaJson    Json?    @map("meta_json")
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorUserId], references: [id])

  @@map("audit_logs")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum BriefStatus {
  DRAFT
  SUBMITTED
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ProvisioningStatus {
  DRAFT
  PAYMENT_REQUIRED
  QUEUED
  PROVISIONING
  READY
  FAILED
  SUSPENDED
}

enum ProvisioningStep {
  NONE
  CREATE_SERVER
  WAIT_SSH
  APPLY_TERRAFORM
  HEALTHCHECK
  FINALIZE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum AuthorType {
  USER
  ADMIN
}

model VpnCert {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  name         String
  status       VpnStatus @default(ACTIVE)
  privateKey   String    @map("private_key")
  publicKey    String    @map("public_key")
  presharedKey String    @map("preshared_key")
  createdAt    DateTime  @default(now()) @map("created_at")
  revokedAt    DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vpn_certs")
}

enum VpnStatus {
  ACTIVE
  REVOKED
}

// ── Balance & Billing ────────────────────────────────────────────────────────

model BalanceTransaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  amountKopecks Int           @map("amount_kopecks")  // + пополнение, - списание
  type        TxType
  description String
  meta        Json?           // provider payment id, assistantId, etc
  createdAt   DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("balance_transactions")
}

model AssistantSubscription {
  id              String     @id @default(uuid())
  userId          String     @map("user_id")
  briefId         String     @map("brief_id")
  status          SubStatus  @default(ACTIVE)
  priceKopecks    Int        @map("price_kopecks")   // стоимость в месяц
  billingCycleDay Int        @default(1) @map("billing_cycle_day") // день списания
  nextBillingAt   DateTime   @map("next_billing_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brief Brief @relation(fields: [briefId], references: [id], onDelete: Cascade)

  @@map("assistant_subscriptions")
}

enum TxType {
  TOPUP       // пополнение (платёж)
  CHARGE      // списание за ассистента
  REFUND      // возврат
  BONUS       // бонус от администратора
  ADJUSTMENT  // ручная корректировка
}

enum SubStatus {
  ACTIVE
  PAUSED
  CANCELLED
}
