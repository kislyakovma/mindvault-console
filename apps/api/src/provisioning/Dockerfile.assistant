FROM node:22-slim

# Системные зависимости
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git python3 python3-pip python3-venv \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Устанавливаем openai-whisper глобально (CLI + library)
RUN pip3 install --no-cache-dir --break-system-packages openai-whisper 2>&1 | tail -3

# Скачиваем модель base заранее (чтобы не качалась при первом запуске)
RUN python3 -c "import whisper; whisper.load_model('base')" 2>&1 | tail -2

# Устанавливаем openclaw глобально
ARG OPENCLAW_VERSION=latest
RUN npm install -g openclaw@${OPENCLAW_VERSION} --ignore-scripts 2>&1 | tail -3

# Создаём непривилегированного пользователя
RUN useradd -m -u 1001 -s /bin/bash oc

USER oc
WORKDIR /home/oc

# Конфиг и workspace монтируются снаружи как volume
VOLUME ["/home/oc/.openclaw"]

EXPOSE 19465

ENTRYPOINT ["openclaw", "gateway"]
